# Server
PORT=8080
ENV=development
CORS_ORIGIN=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/nitipin?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
PASSWORD_RESET_TOKEN_EXPIRY=1h
EMAIL_VERIFY_TOKEN_EXPIRY=24h

# Platform
PLATFORM_FEE_PERCENT=5.0

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# External services (optional for dev)
# MIDTRANS_SERVER_KEY=
# S3_ENDPOINT=
# S3_BUCKET=nitipin
# SENDGRID_API_KEY=
# GOOGLE_CLIENT_ID=
